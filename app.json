{
  "expo": {
    "name": "ELAS",
    "slug": "elas",
    "owner": "elas-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "elas",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.elasapp.app",
      "infoPlist": {
        "NSContactsUsageDescription": "ELAS precisa acessar seus contatos para avisar sua rede de confiança em emergências.",
        "NSLocationWhenInUseUsageDescription": "ELAS precisa da sua localização pra enviar pras amigas em caso de emergência.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ELAS precisa da sua localização pra Modo Seguro funcionar mesmo com app fechado.",
        "NSFaceIDUsageDescription": "ELAS usa Face ID pra proteger o seu Cofre. Só você abre os arquivos guardados.",
        "NSPhotoLibraryUsageDescription": "ELAS precisa acessar suas fotos pra você salvar no Cofre. As fotos selecionadas são criptografadas — nem o ELAS pode ver.",
        "NSPhotoLibraryAddUsageDescription": "ELAS pode salvar fotos do Cofre de volta na sua galeria se você pedir.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F1A"
      },
      "package": "br.com.elasapp.app",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "READ_CONTACTS",
        "SEND_SMS",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-quick-actions",
        {
          "androidIcons": {
            "shortcut_unlock": {
              "foregroundImage": "./assets/adaptive-icon.png",
              "backgroundColor": "#0F0F1A"
            }
          },
          "iosActions": [
            {
              "id": "unlock",
              "title": "Desbloquear",
              "icon": "symbol:lock.open",
              "params": {
                "href": "/sos-unlock"
              }
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ea2d7190-02dc-4d76-8933-375177a3e304"
      }
    }
  }
}
