{
  "expo": {
    "name": "SafetyDate",
    "slug": "safetydate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "safetydate",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safetydate.app",
      "infoPlist": {
        "NSContactsUsageDescription": "SafetyDate precisa acessar seus contatos para o modo de emergência.",
        "NSLocationWhenInUseUsageDescription": "SafetyDate precisa da sua localização para compartilhar em encontros."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F1A"
      },
      "package": "com.safetydate.app",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "READ_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "react-native-purchases",
        {
          "usesStoreKit2IfAvailable": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
